        <rdfs:label>Bookings Analytics</rdfs:label>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.com/cisco/bookings/ontology#quoteToBookingFlow">
        <rdf:type rdf:resource="http://example.com/cisco/bookings/ontology#ProcessActivity"/>
        <rdfs:label>Quote-to-Booking Flow</rdfs:label>
        <ex:processDescription>Front portion of the Order-to-Cash cycle beginning when a qualified opportunity is ready to transact and ending when a valid customer order is accepted and recognized as a booking.</ex:processDescription>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/cisco/bookings/ontology#renewalLoop">
        <rdf:type rdf:resource="http://example.com/cisco/bookings/ontology#ProcessActivity"/>
        <rdfs:label>Renewal Loop</rdfs:label>
        <ex:processDescription>Renewal lifecycle in which upcoming expirations are managed and renewal bookings flow back into the booking fact population.</ex:processDescription>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.com/cisco/bookings/ontology#salesAccountExecutiveRole">
        <rdf:type rdf:resource="http://example.com/cisco/bookings/ontology#SalesAccountExecutive"/>
        <ex:responsibilityDescription>Qualifies opportunity, owns the customer relationship and the booking.</ex:responsibilityDescription>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/cisco/bookings/ontology#dealDeskRole">
        <rdf:type rdf:resource="http://example.com/cisco/bookings/ontology#DealDesk"/>
        <ex:responsibilityDescription>Approves non-standard pricing and structures the commercial terms.</ex:responsibilityDescription>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/cisco/bookings/ontology#revenueOperationsRole">
        <rdf:type rdf:resource="http://example.com/cisco/bookings/ontology#RevenueOperations"/>
        <ex:responsibilityDescription>Owns booking definitions, ACV/TCV rules and bookings reporting.</ex:responsibilityDescription>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/cisco/bookings/ontology#customerExperienceRenewalsRole">
        <rdf:type rdf:resource="http://example.com/cisco/bookings/ontology#CustomerExperienceRenewals"/>
        <ex:responsibilityDescription>Owns entitlements, install base and the renewal lifecycle.</ex:responsibilityDescription>
    </owl:NamedIndividual>

    <rdf:Description rdf:about="http://example.com/cisco/bookings/ontology#OpportunityQualification">
        <ex:processDescription>Account executive qualifies the opportunity; customer segment and coverage model are confirmed.</ex:processDescription>
        <ex:performedBy rdf:resource="http://example.com/cisco/bookings/ontology#salesAccountExecutiveRole"/>
        <ex:precedesProcess rdf:resource="http://example.com/cisco/bookings/ontology#QuoteConfiguration"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.com/cisco/bookings/ontology#QuoteConfiguration">
        <ex:processDescription>Products are configured, list pricing is applied, and discounts route to Deal Desk for approval.</ex:processDescription>
        <ex:performedBy rdf:resource="http://example.com/cisco/bookings/ontology#dealDeskRole"/>
        <ex:precedesProcess rdf:resource="http://example.com/cisco/bookings/ontology#DealRegistration"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.com/cisco/bookings/ontology#DealRegistration">
        <ex:processDescription>For channel deals, the partner registers the opportunity and route-to-market is set.</ex:processDescription>
        <ex:precedesProcess rdf:resource="http://example.com/cisco/bookings/ontology#OrderPlacement"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.com/cisco/bookings/ontology#OrderPlacement">
        <ex:processDescription>The customer or partner submits a purchase order, which is validated for configuration and commercial terms.</ex:processDescription>
        <ex:precedesProcess rdf:resource="http://example.com/cisco/bookings/ontology#BookingRecognition"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.com/cisco/bookings/ontology#BookingRecognition">
        <ex:processDescription>A valid accepted order is booked; booking amount, ACV and TCV are computed and the booking is classified.</ex:processDescription>
        <ex:precedesProcess rdf:resource="http://example.com/cisco/bookings/ontology#FulfillmentProvisioning"/>
        <ex:downstreamConsumedBy rdf:resource="http://example.com/cisco/bookings/ontology#Finance"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.com/cisco/bookings/ontology#FulfillmentProvisioning">
        <ex:processDescription>Hardware is shipped; software and SaaS entitlements are provisioned.</ex:processDescription>
        <ex:precedesProcess rdf:resource="http://example.com/cisco/bookings/ontology#ContractEntitlementCreation"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.com/cisco/bookings/ontology#ContractEntitlementCreation">
        <ex:processDescription>A service or subscription contract is created with coverage level, term and renewal date context.</ex:processDescription>
        <ex:precedesProcess rdf:resource="http://example.com/cisco/bookings/ontology#RenewalLifecycle"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.com/cisco/bookings/ontology#RenewalLifecycle">
        <ex:processDescription>Customer Experience manages upcoming expirations; renewal bookings flow back into booking analytics.</ex:processDescription>
    </rdf:Description>

</rdf:RDF>