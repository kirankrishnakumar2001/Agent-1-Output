<?xml version="1.0"?>
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:skos="http://www.w3.org/2004/02/skos/core#"
    xmlns:ex="http://example.com/cisco/bookings/ontology#"
    xml:base="http://example.com/cisco/bookings/ontology">

    <owl:Ontology rdf:about="http://example.com/cisco/bookings/ontology">
        <rdfs:label xml:lang="en">Cisco Bookings Enterprise Ontology</rdfs:label>
        <rdfs:comment xml:lang="en">Enterprise OWL ontology generated from the provided OSI semantic model, glossary, SQL DDL, and Quote-to-Booking business process documentation. The ontology models booking analytics at booked order-line grain and the supporting dimensions, process stages, roles, and reasoning constraints. Explicit source semantics are preserved; inferred axioms are annotated in comments.</rdfs:comment>
        <owl:versionInfo>1.0.0</owl:versionInfo>
    </owl:Ontology>

    <owl:Class rdf:about="http://example.com/cisco/bookings/ontology#BusinessEntity">
        <rdfs:label>Business Entity</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://example.com/cisco/bookings/ontology#BusinessDomain">
        <rdfs:label>Business Domain</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://example.com/cisco/bookings/ontology#ProcessActivity">
        <rdfs:label>Process Activity</rdfs:label>
        <rdfs:comment>Abstract class for Quote-to-Booking process activities from the business process document.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.com/cisco/bookings/ontology#Role">
        <rdfs:label>Role</rdfs:label>
        <rdfs:comment>Business role with responsibility in the Quote-to-Booking process.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.com/cisco/bookings/ontology#Date">
        <rdfs:subClassOf rdf:resource="http://example.com/cisco/bookings/ontology#BusinessEntity"/>
        <rdfs:label>Date</rdfs:label>
        <rdfs:comment>Stores calendar and fiscal date information used for analyzing bookings across different time periods.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.com/cisco/bookings/ontology#Customer">
        <rdfs:subClassOf rdf:resource="http://example.com/cisco/bookings/ontology#BusinessEntity"/>
        <rdfs:label>Customer</rdfs:label>
        <rdfs:comment>Contains descriptive information about customers who purchase products or services.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.com/cisco/bookings/ontology#Product">
        <rdfs:subClassOf rdf:resource="http://example.com/cisco/bookings/ontology#BusinessEntity"/>
        <rdfs:label>Product</rdfs:label>
        <rdfs:comment>Contains descriptive information about products and services sold through bookings.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.com/cisco/bookings/ontology#Partner">
        <rdfs:subClassOf rdf:resource="http://example.com/cisco/bookings/ontology#BusinessEntity"/>
        <rdfs:label>Partner</rdfs:label>
        <rdfs:comment>Stores information about channel partners involved in selling products.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.com/cisco/bookings/ontology#Geography">
        <rdfs:subClassOf rdf:resource="http://example.com/cisco/bookings/ontology#BusinessEntity"/>
        <rdfs:label>Geography</rdfs:label>
        <rdfs:comment>Provides hierarchical geographic information for analyzing bookings across global regions.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.com/cisco/bookings/ontology#SalesRepresentative">
        <rdfs:subClassOf rdf:resource="http://example.com/cisco/bookings/ontology#BusinessEntity"/>
        <rdfs:label>Sales Representative</rdfs:label>
        <rdfs:comment>Contains information about sales representatives responsible for customer bookings.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.com/cisco/bookings/ontology#Contract">
        <rdfs:subClassOf rdf:resource="http://example.com/cisco/bookings/ontology#BusinessEntity"/>
        <rdfs:label>Contract</rdfs:label>
        <rdfs:comment>Stores information describing customer contracts associated with bookings.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.com/cisco/bookings/ontology#Booking">
        <rdfs:subClassOf rdf:resource="http://example.com/cisco/bookings/ontology#BusinessEntity"/>
        <rdfs:label>Booking</rdfs:label>
        <rdfs:comment>Measurable business transaction representing a booked order line.</rdfs:comment>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.com/cisco/bookings/ontology#occursOn"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.com/cisco/bookings/ontology#Date"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.com/cisco/bookings/ontology#forCustomer"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.com/cisco/bookings/ontology#Customer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.com/cisco/bookings/ontology#includesProduct"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.com/cisco/bookings/ontology#Product"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.com/cisco/bookings/ontology#soldThroughPartner"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.com/cisco/bookings/ontology#Partner"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.com/cisco/bookings/ontology#associatedWithGeography"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.com/cisco/bookings/ontology#Geography"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.com/cisco/bookings/ontology#ownedBySalesRepresentative"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.com/cisco/bookings/ontology#SalesRepresentative"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.com/cisco/bookings/ontology#governedByContract"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.com/cisco/bookings/ontology#Contract"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="http://example.com/cisco/bookings/ontology#OpportunityQualification">
        <rdfs:subClassOf rdf:resource="http://example.com/cisco/bookings/ontology#ProcessActivity"/>
        <rdfs:label>Opportunity Qualification</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://example.com/cisco/bookings/ontology#QuoteConfiguration">
        <rdfs:subClassOf rdf:resource="http://example.com/cisco/bookings/ontology#ProcessActivity"/>
        <rdfs:label>Quote Configuration</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://example.com/cisco/bookings/ontology#DealRegistration">
        <rdfs:subClassOf rdf:resource="http://example.com/cisco/bookings/ontology#ProcessActivity"/>
        <rdfs:label>Deal Registration</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://example.com/cisco/bookings/ontology#OrderPlacement">
        <rdfs:subClassOf rdf:resource="http://example.com/cisco/bookings/ontology#ProcessActivity"/>
        <rdfs:label>Order Placement</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://example.com/cisco/bookings/ontology#BookingRecognition">
        <rdfs:subClassOf rdf:resource="http://example.com/cisco/bookings/ontology#ProcessActivity"/>
        <rdfs:label>Booking Recognition</rdfs:label>
        <rdfs:comment>A valid accepted order is recognized as a booking with booking amount, ACV, and TCV computed.</rdfs:comment>
    </owl:Class>
    <owl:Class rdf:about="http://example.com/cisco/bookings/ontology#FulfillmentProvisioning">
        <rdfs:subClassOf rdf:resource="http://example.com/cisco/bookings/ontology#ProcessActivity"/>
        <rdfs:label>Fulfillment and Provisioning</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://example.com/cisco/bookings/ontology#ContractEntitlementCreation">
        <rdfs:subClassOf rdf:resource="http://example.com/cisco/bookings/ontology#ProcessActivity"/>
        <rdfs:label>Contract and Entitlement Creation</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://example.com/cisco/bookings/ontology#RenewalLifecycle">
        <rdfs:subClassOf rdf:resource="http://example.com/cisco/bookings/ontology#ProcessActivity"/>
        <rdfs:label>Renewal Lifecycle</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://example.com/cisco/bookings/ontology#SalesAccountExecutive">
        <rdfs:subClassOf rdf:resource="http://example.com/cisco/bookings/ontology#Role"/>
        <rdfs:label>Sales / Account Executive</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://example.com/cisco/bookings/ontology#DealDesk">
        <rdfs:subClassOf rdf:resource="http://example.com/cisco/bookings/ontology#Role"/>
        <rdfs:label>Deal Desk</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://example.com/cisco/bookings/ontology#RevenueOperations">
        <rdfs:subClassOf rdf:resource="http://example.com/cisco/bookings/ontology#Role"/>
        <rdfs:label>Revenue Operations</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://example.com/cisco/bookings/ontology#ChannelPartnerOrganization">
        <rdfs:subClassOf rdf:resource="http://example.com/cisco/bookings/ontology#Role"/>
        <rdfs:label>Channel / Partner Organization</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://example.com/cisco/bookings/ontology#CustomerExperienceRenewals">
        <rdfs:subClassOf rdf:resource="http://example.com/cisco/bookings/ontology#Role"/>
        <rdfs:label>Customer Experience (Renewals)</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://example.com/cisco/bookings/ontology#Finance">
        <rdfs:subClassOf rdf:resource="http://example.com/cisco/bookings/ontology#Role"/>
        <rdfs:label>Finance</rdfs:label>
    </owl:Class>

    <owl:AllDisjointClasses>
        <owl:members rdf:parseType="Collection">
            <rdf:Description rdf:about="http://example.com/cisco/bookings/ontology#Date"/>
            <rdf:Description rdf:about="http://example.com/cisco/bookings/ontology#Customer"/>
            <rdf:Description rdf:about="http://example.com/cisco/bookings/ontology#Product"/>
            <rdf:Description rdf:about="http://example.com/cisco/bookings/ontology#Partner"/>
            <rdf:Description rdf:about="http://example.com/cisco/bookings/ontology#Geography"/>
            <rdf:Description rdf:about="http://example.com/cisco/bookings/ontology#SalesRepresentative"/>
            <rdf:Description rdf:about="http://example.com/cisco/bookings/ontology#Contract"/>
            <rdf:Description rdf:about="http://example.com/cisco/bookings/ontology#Booking"/>
        </owl:members>
    </owl:AllDisjointClasses>

    <owl:ObjectProperty rdf:about="http://example.com/cisco/bookings/ontology#occursOn">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#Booking"/>
        <rdfs:range rdf:resource="http://example.com/cisco/bookings/ontology#Date"/>
        <rdfs:label>occurs on</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.com/cisco/bookings/ontology#dateOfBooking">
        <owl:inverseOf rdf:resource="http://example.com/cisco/bookings/ontology#occursOn"/>
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#Date"/>
        <rdfs:range rdf:resource="http://example.com/cisco/bookings/ontology#Booking"/>
        <rdfs:label>date of booking</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.com/cisco/bookings/ontology#forCustomer">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#Booking"/>
        <rdfs:range rdf:resource="http://example.com/cisco/bookings/ontology#Customer"/>
        <rdfs:label>for customer</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.com/cisco/bookings/ontology#hasBooking">
        <owl:inverseOf rdf:resource="http://example.com/cisco/bookings/ontology#forCustomer"/>
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#Customer"/>
        <rdfs:range rdf:resource="http://example.com/cisco/bookings/ontology#Booking"/>
        <rdfs:label>has booking</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.com/cisco/bookings/ontology#includesProduct">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#Booking"/>
        <rdfs:range rdf:resource="http://example.com/cisco/bookings/ontology#Product"/>
        <rdfs:label>includes product</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.com/cisco/bookings/ontology#productInBooking">
        <owl:inverseOf rdf:resource="http://example.com/cisco/bookings/ontology#includesProduct"/>
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#Product"/>
        <rdfs:range rdf:resource="http://example.com/cisco/bookings/ontology#Booking"/>
        <rdfs:label>product in booking</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.com/cisco/bookings/ontology#soldThroughPartner">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#Booking"/>
        <rdfs:range rdf:resource="http://example.com/cisco/bookings/ontology#Partner"/>
        <rdfs:label>sold through partner</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.com/cisco/bookings/ontology#partnerBooking">
        <owl:inverseOf rdf:resource="http://example.com/cisco/bookings/ontology#soldThroughPartner"/>
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#Partner"/>
        <rdfs:range rdf:resource="http://example.com/cisco/bookings/ontology#Booking"/>
        <rdfs:label>partner booking</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.com/cisco/bookings/ontology#associatedWithGeography">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#Booking"/>
        <rdfs:range rdf:resource="http://example.com/cisco/bookings/ontology#Geography"/>
        <rdfs:label>associated with geography</rdfs:label>
        <rdfs:comment>Glossary uses geo_key while SQL DDL uses geography_key; treated as semantically equivalent with medium confidence.</rdfs:comment>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.com/cisco/bookings/ontology#geographyOfBooking">
        <owl:inverseOf rdf:resource="http://example.com/cisco/bookings/ontology#associatedWithGeography"/>
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#Geography"/>
        <rdfs:range rdf:resource="http://example.com/cisco/bookings/ontology#Booking"/>
        <rdfs:label>geography of booking</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.com/cisco/bookings/ontology#ownedBySalesRepresentative">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#Booking"/>
        <rdfs:range rdf:resource="http://example.com/cisco/bookings/ontology#SalesRepresentative"/>
        <rdfs:label>owned by sales representative</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.com/cisco/bookings/ontology#ownsBooking">
        <owl:inverseOf rdf:resource="http://example.com/cisco/bookings/ontology#ownedBySalesRepresentative"/>
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#SalesRepresentative"/>
        <rdfs:range rdf:resource="http://example.com/cisco/bookings/ontology#Booking"/>
        <rdfs:label>owns booking</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.com/cisco/bookings/ontology#governedByContract">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#Booking"/>
        <rdfs:range rdf:resource="http://example.com/cisco/bookings/ontology#Contract"/>
        <rdfs:label>governed by contract</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.com/cisco/bookings/ontology#contractForBooking">
        <owl:inverseOf rdf:resource="http://example.com/cisco/bookings/ontology#governedByContract"/>
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#Contract"/>
        <rdfs:range rdf:resource="http://example.com/cisco/bookings/ontology#Booking"/>
        <rdfs:label>contract for booking</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.com/cisco/bookings/ontology#precedesProcess">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#ProcessActivity"/>
        <rdfs:range rdf:resource="http://example.com/cisco/bookings/ontology#ProcessActivity"/>
        <rdfs:label>precedes process</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.com/cisco/bookings/ontology#performedBy">
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#ProcessActivity"/>
        <rdfs:range rdf:resource="http://example.com/cisco/bookings/ontology#Role"/>
        <rdfs:label>performed by</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.com/cisco/bookings/ontology#performsActivity">
        <owl:inverseOf rdf:resource="http://example.com/cisco/bookings/ontology#performedBy"/>
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#Role"/>
        <rdfs:range rdf:resource="http://example.com/cisco/bookings/ontology#ProcessActivity"/>
        <rdfs:label>performs activity</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.com/cisco/bookings/ontology#governsActivity">
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#Role"/>
        <rdfs:range rdf:resource="http://example.com/cisco/bookings/ontology#ProcessActivity"/>
        <rdfs:label>governs activity</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.com/cisco/bookings/ontology#producesBooking">
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#BookingRecognition"/>
        <rdfs:range rdf:resource="http://example.com/cisco/bookings/ontology#Booking"/>
        <rdfs:label>produces booking</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.com/cisco/bookings/ontology#establishesContract">
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#ContractEntitlementCreation"/>
        <rdfs:range rdf:resource="http://example.com/cisco/bookings/ontology#Contract"/>
        <rdfs:label>establishes contract</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.com/cisco/bookings/ontology#mayGenerateBooking">
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#RenewalLifecycle"/>
        <rdfs:range rdf:resource="http://example.com/cisco/bookings/ontology#Booking"/>
        <rdfs:label>may generate booking</rdfs:label>
        <rdfs:comment>Represents the documented rule that renewal bookings flow back into the booking fact population.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.com/cisco/bookings/ontology#downstreamConsumedBy">
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#BookingRecognition"/>
        <rdfs:range rdf:resource="http://example.com/cisco/bookings/ontology#Finance"/>
        <rdfs:label>downstream consumed by</rdfs:label>
    </owl:ObjectProperty>

    <owl:DatatypeProperty rdf:about="http://example.com/cisco/bookings/ontology#dateKey">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#Date"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>date key</rdfs:label>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.com/cisco/bookings/ontology#fullDate">
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#Date"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label>full date</rdfs:label>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.com/cisco/bookings/ontology#monthName">
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#Date"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>month name</rdfs:label>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.com/cisco/bookings/ontology#calendarYear">
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#Date"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>calendar year</rdfs:label>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.com/cisco/bookings/ontology#fiscalYear">
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#Date"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>fiscal year</rdfs:label>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.com/cisco/bookings/ontology#fiscalQuarter">
        <rdfs:domain rdf:resource="http://example.com/cisco/bookings/ontology#Date"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>fiscal quarter</rdfs:label>
